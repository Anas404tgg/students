# ──────────────────────────────────────────────────────────────
# Student Management System — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL (required — use Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/sms_db?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth (optional — uncomment to enable) ───────────────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Application ──────────────────────────────────────────────
NODE_ENV="development"
APP_NAME="Student Management System"
APP_URL="http://localhost:3000"

# ─── Rate Limiting ────────────────────────────────────────────
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# ─── Redis (optional caching layer) ──────────────────────────
# REDIS_URL="redis://localhost:6379"

# ─── Sentry (optional error tracking) ────────────────────────
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL="info"

# ─── File Upload ──────────────────────────────────────────────
# MAX_FILE_SIZE_MB=5
# UPLOAD_DIR="./uploads"

# ─── Docker / Production ─────────────────────────────────────
# PORT=3000
# HOSTNAME="0.0.0.0"
